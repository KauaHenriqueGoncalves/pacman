<Page
    x:Class="CapstonePacMan.Presentation.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CapstonePacMan.Presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#000000">

    <Page.DataContext>
        <local:GamePageViewModel/>
    </Page.DataContext>

    <Grid>

        <Border Background="#AA000000"
                Height="50"
                VerticalAlignment="Top">

            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <TextBlock Text="Vidas"
                               FontSize="18"
                               Foreground="Red"/>
                    <TextBlock Text="{Binding Vidas}"
                               FontSize="18"
                               Foreground="Red"
                               FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <TextBlock Text="Pontos"
                               FontSize="18"
                               Foreground="Yellow"/>
                    <TextBlock Text="{Binding Score}"
                               FontSize="18"
                               Foreground="Yellow"
                               FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border BorderBrush="#444"
                BorderThickness="2"
                CornerRadius="8"
                Padding="8"
                Margin="0,60,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">

            <Canvas x:Name="GameCanvas"
                    Width="800"
                    Height="600"
                    Background="#020202"
                    TabIndex="0"
                    IsTabStop="True"
                    PointerPressed="GameCanvas_PointerPressed"
                    KeyDown="OnCanvasKeyDown"/>
        </Border>
    </Grid>
</Page>
